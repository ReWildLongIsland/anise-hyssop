# Auth0 SPA Application
# Found in Auth0 Dashboard > Applications > Anise Hyssop (SPA) > Settings
VITE_AUTH0_DOMAIN=dev-i7s07siq4nnbdklq.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id_here

# Must match AUTH0_AUDIENCE in the backend .env exactly
VITE_AUTH0_AUDIENCE=https://volunteer.rewildlongisland.org/api

# Backend URL — Vite proxy rewrites /api/* in dev, so this is only needed
# for environments where the proxy isn't used (e.g., production builds)
VITE_API_URL=http://localhost:8000
