# Auth0
# SPA application domain (same for both dev and prod tenants)
AUTH0_DOMAIN=dev-i7s07siq4nnbdklq.us.auth0.com

# The API identifier you define in Auth0 > APIs
AUTH0_AUDIENCE=https://volunteer.rewildlongisland.org/api

# Machine-to-Machine app credentials (Auth0 > Applications > Anise Hyssop M2M)
# Used for Management API calls: email changes, user deletion
AUTH0_M2M_CLIENT_ID=your_m2m_client_id_here
AUTH0_M2M_CLIENT_SECRET=your_m2m_client_secret_here

# Google Sheets
# Path to the service account JSON key file (do NOT commit this file)
GOOGLE_CREDENTIALS_FILE=./credentials/service-account.json

# Copy Sheet IDs from the URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
VOLUNTEERS_SHEET_ID=your_volunteers_sheet_id_here
MEMBERSHIPS_SHEET_ID=your_memberships_sheet_id_here
TEAMS_SHEET_ID=your_teams_config_sheet_id_here

# App
# Frontend origin for CORS — change to production URL on deploy
FRONTEND_URL=http://localhost:5173
